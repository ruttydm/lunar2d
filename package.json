{
  "name": "lunar3d",
  "version": "0.1.0",
  "devDependencies": {
    "typescript": "^5.7.0",
    "vite": "^6.2.0"
  },
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "server": "bun run --watch src/server/main.ts",
    "wasm:build": "cd crates/lunar-physics-wasm && wasm-pack build --target web --dev --out-dir ../../pkg",
    "wasm:release": "cd crates/lunar-physics-wasm && wasm-pack build --target web --release --out-dir ../../pkg",
    "test:rust": "cargo test",
    "test": "cargo test"
  },
  "type": "module"
}
