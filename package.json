{
  "name": "lunar3d",
  "version": "0.1.0",
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@types/bun": "^1.3.13",
    "typescript": "^5.7.0",
    "vite": "^6.2.0"
  },
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "server": "bun run --watch src/server/main.ts",
    "typecheck": "tsc --noEmit",
    "test:unit": "bun test tests/physics tests/systems",
    "test:e2e": "playwright test",
    "check": "bun run typecheck && bun run test:unit && bun run build && bun build src/server/main.ts --target=bun --outfile=/tmp/lunar2d-server-check.js",
    "test": "bun run test:unit"
  },
  "type": "module"
}
